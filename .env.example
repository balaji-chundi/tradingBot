# ============================================================
# Copy to .env and fill in. .env is gitignored.
# ============================================================

# --- Angel One SmartAPI (Phase 1) ---
# Apply at https://smartapi.angelone.in/ to get an API key.
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_MPIN=
ANGELONE_TOTP_SECRET=

# --- Google Gemini API (Phase 4) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model IDs are confirmed when creating the key — these are placeholders.
# Tier 1 (15-min regime check): a Pro-class model with stronger reasoning.
# Tier 2 (per-trade gut-check): Flash Lite for sub-2.5s latency.
GEMINI_MODEL_TIER1=gemini-2.5-pro
GEMINI_MODEL_TIER2=gemini-2.5-flash-lite

# --- Trading config ---
CAPITAL_INR=50000
BROKER_MODE=paper           # paper | live
DAILY_LOSS_LIMIT_INR=1500
WEEKLY_LOSS_LIMIT_INR=3000
RISK_PER_TRADE_PCT=1.0
MAX_TRADES_PER_DAY=2
PRETRADE_LLM_CHECK=true
RESPECT_REGIME=true

# --- Runtime ---
LOG_LEVEL=INFO
LOG_DIR=logs
DB_PATH=data/journal.db
